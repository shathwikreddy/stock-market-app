generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watchlist  Watchlist?
  notes      Note[]
  portfolios Portfolio[]
}

model Watchlist {
  id        String           @id @default(uuid())
  userId    String           @unique
  name      String           @default("My Watchlist")
  stocks    WatchlistStock[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WatchlistStock {
  id            String            @id @default(uuid())
  watchlistId   String
  sNo           Int
  date          DateTime          @default(now())
  sourceFrom    String
  segments      String
  tradingSymbol String
  sector        String
  industry      String
  ltp           Float
  entryPrice    Float
  stopLoss      Float
  target        Float
  redFlags      String            @default("")
  note          String            @default("")
  category      WatchlistCategory
  addedAt       DateTime          @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
}

enum WatchlistCategory {
  intraday
  fno
  swing
  positional
  multibagger
}

model Note {
  id        String    @id @default(uuid())
  userId    String
  title     String
  content   String    @default("")
  color     NoteColor @default(slate)
  isPinned  Boolean   @default(false)
  tags      String[]  @default([])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPinned, updatedAt])
}

enum NoteColor {
  slate
  zinc
  stone
  neutral
  gray
  dark
}

enum MarketCondition {
  BullMarket       @map("Bull Market")
  BullishToBearish @map("Bullish to Bearish")
  SideWaysMarket   @map("Side Ways Market")
  BearMarket       @map("Bear Market")
  BearishToBullish @map("Bearish to Bullish")
}

model Portfolio {
  id              String           @id @default(uuid())
  userId          String
  marketCondition MarketCondition
  totalCapital    Float            @default(100000)
  strategies      Strategy[]
  experienceNotes ExperienceNote[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, marketCondition])
}

model Strategy {
  id                String @id @default(uuid())
  portfolioId       String
  name              String
  allocationPercent Float  @default(0)
  allocationRupees  Float  @default(0)
  usedFunds         Float  @default(0)
  unusedFunds       Float  @default(0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model ExperienceNote {
  id          String @id @default(uuid())
  portfolioId String
  positive    String @default("")
  negative    String @default("")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model StockMaster {
  id              String    @id @default(uuid())
  securityId      Int
  tradingSymbol   String
  displayName     String
  exchange        String
  exchangeSegment String
  series          String    @default("")
  instrumentType  String    @default("ES")
  isin            String    @default("")
  faceValue       Float     @default(1)
  sector          String    @default("-")
  industry        String    @default("-")
  marketCapValue  Float     @default(0)
  enrichedAt      DateTime?
  refreshedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([securityId, exchange])
  @@index([exchange])
  @@index([isin])
}

model HistoricalPrice {
  id              String   @id @default(uuid())
  securityId      Int
  exchangeSegment String
  closes          Float[]  @default([])
  timestamps      Float[]  @default([])
  lastDate        String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([securityId, exchangeSegment])
  @@index([exchangeSegment])
}

model PriceSnapshot {
  id        String   @id @default(uuid())
  timestamp DateTime
  prices    Json

  @@index([timestamp])
}
